# ─── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# ─── Database ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/app

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Use distinct, random secrets of at least 32 characters in every environment.
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change_me_to_a_random_secret_at_least_32_chars
# Keep the access token short-lived — revocation is enforced at refresh time via
# the rotating, server-side refresh-session store.
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_to_a_different_random_secret_32_chars
JWT_REFRESH_EXPIRES_IN=30d

# ─── CORS ─────────────────────────────────────────────────────────────────────
# "*" to allow any origin, or a comma-separated allow-list:
# CORS_ORIGIN=https://app.example.com,https://admin.example.com
CORS_ORIGIN=http://localhost:3000

# ─── Rate limiting (applied to /api) ────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── Reverse proxy ──────────────────────────────────────────────────────────────
# Number of proxies in front of the app (1 behind a single LB/nginx), 0 to disable.
TRUST_PROXY=0

# ─── Media storage (Cloudinary) ─────────────────────────────────────────────────
# Public photos + private (authenticated) ownership documents.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Max upload size per file in bytes (5MB default).
UPLOAD_MAX_BYTES=5242880

# ─── Blockchain (Increment 2 — on-chain property titles) ────────────────────────
# EVM RPC (e.g. a local Hardhat node at http://127.0.0.1:8545), the deployed
# PropertyTitle contract address, and the custodial minter wallet private key.
BLOCKCHAIN_RPC_URL=
TITLE_CONTRACT_ADDRESS=
MINTER_PRIVATE_KEY=
